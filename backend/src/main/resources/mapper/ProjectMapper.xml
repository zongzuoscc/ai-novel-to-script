<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.novel2script.backend.project.ProjectMapper">

    <resultMap id="ProjectResultMap" type="com.novel2script.backend.project.Project">
        <id property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <insert id="insert" parameterType="com.novel2script.backend.project.Project" useGeneratedKeys="true" keyProperty="id">
        insert into projects (title, status)
        values (#{title}, #{status})
    </insert>

    <select id="findById" resultMap="ProjectResultMap">
        select id, title, status, created_at, updated_at
        from projects
        where id = #{id}
    </select>

    <update id="updateStatus">
        update projects
        set status = #{status},
            updated_at = current_timestamp
        where id = #{id}
    </update>
</mapper>
